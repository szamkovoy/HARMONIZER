# Скопируйте в `.env.local` и заполните локально. Файлы `.env.local` в git не коммитятся.

# Expo (мобильный клиент): URL origin развёрнутого `_legacy_web` с маршрутом /api/communicator
EXPO_PUBLIC_COMMUNICATOR_API_URL=https://your-app.vercel.app
# Те же значения, что и для веба, но с префиксом EXPO_PUBLIC_ (для Supabase в RN)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (публичные — только NEXT_PUBLIC_* в клиенте)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google AI Studio / Gemini (серверный ключ, не NEXT_PUBLIC)
GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=
# Опционально: первая модель в цепочке; если не задано — см. MODEL_CHAIN_DEFAULT в app/api/communicator/route.ts
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Прочие серверные ключи (не NEXT_PUBLIC)
HUME_API_KEY=
OPENAI_API_KEY=
